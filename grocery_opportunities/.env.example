# Notion: create an integration at https://www.notion.so/my-integrations
# Share your target database/page with the integration.
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: score threshold (0–100). Opportunities above this get Status = "Decision Required"
OPPORTUNITY_SCORE_THRESHOLD=70

# Optional: request timeout in seconds
REQUEST_TIMEOUT=30
